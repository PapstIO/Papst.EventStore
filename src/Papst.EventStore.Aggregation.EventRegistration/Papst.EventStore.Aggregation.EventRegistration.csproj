<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  
  <PropertyGroup>
    <Description>This library enables server applications to store and replay event in an abstract EventStore. This particular library extends the functionality by adding the possibility to register events by attribute</Description>
    <Authors>Marco Papst</Authors>
    <Title>Papst EventStore</Title>
    <PackageId>Papst.EventStore.Aggregation.EventRegistration</PackageId>
    <PackageTags>eventsourcing;eventstore</PackageTags>
    <PackageLicenseUrl>https://github.com/PapstIO/Papst.EventStore/blob/main/LICENSE</PackageLicenseUrl>
    <PackageProjectUrl>https://github.com/PapstIO/Papst.EventStore</PackageProjectUrl>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\Papst.EventStore\Papst.EventStore.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Newtonsoft.Json" />
  </ItemGroup>
</Project>